generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model JobRole {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique
  slug String @unique
  jobs Job[]

  @@map("job_role")
}

model Job {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobRoleId      String     @map("job_role_id") @db.Uuid
  companyName    String     @map("company_name")
  jobRoleName    String     @map("job_role")
  postedDate     DateTime?  @map("posted_date") @db.Date
  url            String     @unique
  cv             String?
  pipelineStatus String     @map("pipeline_status")
  jobsStatus     JobsStatus @default(PendingApply) @map("jobs_status")
  createdAt      DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  role           JobRole    @relation(fields: [jobRoleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([companyName], map: "idx_jobs_company")
  @@index([jobRoleId], map: "idx_jobs_role")
  @@index([pipelineStatus], map: "idx_jobs_pipeline_status")
  @@index([jobsStatus], map: "idx_jobs_jobs_status")
  @@map("jobs")
}

model PipelineRun {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind         String
  status       String
  totalRows    Int?            @map("total_rows")
  totalBatches Int?            @map("total_batches")
  currentBatch Int?            @map("current_batch")
  startedAt    DateTime?       @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime?       @map("finished_at") @db.Timestamptz(6)
  error        String?
  batches      PipelineBatch[]

  @@index([startedAt], map: "idx_pipeline_runs_started_at")
  @@map("pipeline_runs")
}

model PipelineBatch {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId        String      @map("run_id") @db.Uuid
  batchIndex   Int         @map("batch_index")
  rowStart     Int         @map("row_start")
  rowEnd       Int         @map("row_end")
  status       String
  currentStage String?     @map("current_stage")
  startedAt    DateTime?   @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime?   @map("finished_at") @db.Timestamptz(6)
  error        String?
  run          PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([runId, batchIndex])
  @@index([runId], map: "idx_pipeline_batches_run")
  @@map("pipeline_batches")
}

enum JobsStatus {
  PendingApply @map("Pending Apply")
  Applied     @map("Applied")
  InProgress  @map("In Progress")
  Rejected    @map("Rejected")

  @@map("jobs_status")
}
