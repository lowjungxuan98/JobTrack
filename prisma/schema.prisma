generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model JobRole {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique
  slug String @unique
  jobs Job[]

  @@map("job_role")
}

model Job {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobRoleId   String    @map("job_role_id") @db.Uuid
  companyName String    @map("company_name")
  jobRoleName String    @map("job_role")
  postedDate  DateTime? @map("posted_date") @db.Date
  url         String    @unique
  cv          String?
  status      String
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  role        JobRole   @relation(fields: [jobRoleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([companyName], map: "idx_jobs_company")
  @@index([jobRoleId], map: "idx_jobs_role")
  @@index([status], map: "idx_jobs_status")
  @@map("jobs")
}
